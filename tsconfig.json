{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@earendil-works/pi-coding-agent": ["./node_modules/@earendil-works/pi-coding-agent"],
      "@earendil-works/pi-ai": ["./node_modules/@earendil-works/pi-ai"],
      "@earendil-works/pi-tui": ["./node_modules/@earendil-works/pi-tui"]
    }
  },
  "include": [".pi/extensions/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/__tests__/**"]
}
