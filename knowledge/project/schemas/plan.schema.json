{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.dev/schemas/plan.schema.json",
  "title": "Plan",
  "description": "Execution plan for a loom task. Primary machine-readable artifact.",
  "type": "object",
  "required": ["task_id", "steps", "risks", "checkpoints", "created_at", "updated_at"],
  "properties": {
    "task_id": { "type": "string", "pattern": "^TASK-[0-9]{4}-[0-9]+-[a-z0-9-]+$" },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/definitions/plan_step" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/definitions/risk" }
    },
    "checkpoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/checkpoint" }
    },
    "created_at": { "type": "string", "format": "date" },
    "updated_at": { "type": "string", "format": "date" },
    "schema_version": { "type": "string", "default": "1.0.0" }
  },
  "definitions": {
    "plan_step": {
      "type": "object",
      "required": ["step_number", "title", "description", "expected_output", "constraints", "depends_on", "estimated_effort", "status"],
      "properties": {
        "step_number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "description": "Human-readable step title in Russian" },
        "description": { "type": "string", "description": "Human-readable step description in Russian" },
        "expected_output": { "type": "string", "description": "What must be produced" },
        "constraints": { "type": "array", "items": { "type": "string" }, "description": "Invariant IDs and rule IDs applicable to this step" },
        "depends_on": { "type": "array", "items": { "type": "integer" }, "description": "Step numbers this step depends on" },
        "estimated_effort": { "type": "string", "enum": ["small", "medium", "large"] },
        "status": { "type": "string", "enum": ["pending", "in_progress", "done", "blocked"] }
      }
    },
    "risk": {
      "type": "object",
      "required": ["id", "description", "severity", "mitigation"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["high", "medium", "low"] },
        "mitigation": { "type": "string" }
      }
    },
    "checkpoint": {
      "type": "object",
      "required": ["id", "description", "after_step", "verification"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "after_step": { "type": "integer" },
        "verification": { "type": "string" }
      }
    }
  }
}
