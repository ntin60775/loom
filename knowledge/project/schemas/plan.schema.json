{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.dev/schemas/plan.schema.json",
  "title": "Plan",
  "description": "Step-by-step execution plan for a loom task.",
  "type": "object",
  "required": ["task_id", "steps"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Task ID this plan belongs to"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/PlanStep" }
    },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/definitions/Risk" }
    },
    "checkpoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/Checkpoint" }
    }
  },
  "definitions": {
    "PlanStep": {
      "type": "object",
      "required": ["step_number", "title", "description", "expected_output", "status"],
      "properties": {
        "step_number": { "type": "number", "description": "Step number (1-based)" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "expected_output": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "depends_on": { "type": "array", "items": { "type": "number" } },
        "estimated_effort": { "type": "string", "enum": ["small", "medium", "large"], "default": "medium" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "done", "blocked"], "default": "pending" }
      }
    },
    "Risk": {
      "type": "object",
      "required": ["id", "description", "mitigation"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high"], "default": "medium" },
        "mitigation": { "type": "string" }
      }
    },
    "Checkpoint": {
      "type": "object",
      "required": ["id", "description", "after_step", "verification"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "after_step": { "type": "number" },
        "verification": { "type": "string" }
      }
    }
  }
}
