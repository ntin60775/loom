{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.dev/schemas/review.schema.json",
  "title": "Review",
  "description": "Git-based review result for a worker commit. Produced by reviewer subagent.",
  "type": "object",
  "required": ["verdict", "commit", "step_number", "findings", "reviewed_at"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "reject", "needs_discussion"],
      "description": "Review verdict: approve = accept step, reject = return to worker, needs_discussion = human required"
    },
    "commit": {
      "type": "string",
      "description": "Git commit hash that was reviewed"
    },
    "step_number": {
      "type": "number",
      "description": "Plan step number being reviewed"
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/definitions/ReviewFinding" }
    },
    "recommendations": {
      "type": "string",
      "description": "Optional free-form recommendations"
    },
    "reviewer_model": {
      "type": "string",
      "description": "Model used for review (for audit)"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of review"
    }
  },
  "definitions": {
    "ReviewFinding": {
      "type": "object",
      "required": ["severity", "message"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["blocker", "warning", "note"]
        },
        "message": { "type": "string" },
        "file_path": { "type": "string" },
        "line_number": { "type": "number" }
      }
    }
  }
}
