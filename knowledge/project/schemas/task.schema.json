{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loom.dev/schemas/task.schema.json",
  "title": "Task",
  "description": "Primary machine-readable artifact for a loom task. All human-readable derivatives are generated from this file.",
  "type": "object",
  "required": [
    "task_id", "slug", "title", "description", "status",
    "priority", "branch", "invariants", "delivery_units",
    "created_at", "updated_at", "schema_version"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{4}-[0-9]+-[a-z0-9-]+$",
      "description": "Unique task identifier, e.g. TASK-2026-0001-bootstrap"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe short name"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title in Russian (for operator)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description in Russian (for operator)"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "completed", "rejected"],
      "description": "Machine-readable task status"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "default": "medium"
    },
    "branch": {
      "type": "string",
      "description": "Git branch for this task, e.g. task/TASK-2026-0001-bootstrap"
    },
    "parent_task_id": {
      "type": "string",
      "description": "Parent task ID if this is a subtask"
    },
    "parent_delivery_unit": {
      "type": "string",
      "description": "Parent delivery unit ID if this is a subtask of a DU"
    },
    "execution_mode": {
      "type": "string",
      "enum": ["auto", "direct", "subagent"],
      "default": "auto",
      "description": "Режим исполнения: auto (автовыбор по числу шагов плана), direct (агент сам, без worker/reviewer, для ≤3 шагов), subagent (worker → reviewer, для ≥4 шагов). Ручное переопределение."
    },
    "invariants": {
      "type": "array",
      "items": { "$ref": "#/definitions/Invariant" }
    },
    "delivery_units": {
      "type": "array",
      "items": { "$ref": "#/definitions/DeliveryUnit" }
    },
    "created_at": {
      "type": "string",
      "format": "date",
      "description": "ISO date when the task was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date",
      "description": "ISO date when the task was last updated"
    },
    "schema_version": {
      "type": "string",
      "default": "1.0.0"
    }
  },
  "definitions": {
    "Invariant": {
      "type": "object",
      "required": ["id", "text", "marker", "status", "verification_method"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "marker": { "type": "string" },
        "status": { "type": "string", "enum": ["defined", "verified", "failed"], "default": "defined" },
        "verification_method": { "type": "string" }
      }
    },
    "DeliveryUnit": {
      "type": "object",
      "required": ["id", "purpose"],
      "properties": {
        "id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["draft", "in_progress", "completed", "merged"],
          "default": "draft"
        },
        "purpose": { "type": "string" },
        "base_branch": { "type": "string", "default": "main" },
        "subtask_id": { "type": "string" }
      }
    }
  }
}
