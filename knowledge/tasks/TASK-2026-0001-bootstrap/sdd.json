  "deferred_scope": [
    {
      "id": "DEF-1",
      "name": "Memory Layer (session/episodic/semantic/procedural)",
      "rationale": "Requires mature base core. v1 stores knowledge passively. Active management needs ranking, summarization, retention. Threshold: 50+ closed tasks."
    },
    {
      "id": "DEF-2",
      "name": "Scout Retrieval (search_knowledge tool)",
      "rationale": "v1 uses manual reading. Scout subagent search is sufficient until ~50 tasks."
    },
    {
      "id": "DEF-3",
      "name": "Parallel workers in agent mode",
      "rationale": "Intentionally excluded. Sequential execution prevents git conflicts, ensures consistency, simplifies review and rollback."
    }
