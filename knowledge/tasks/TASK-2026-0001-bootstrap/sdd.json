  "flows": [
    {
      "id": "FLOW-plan",
      "name": "Plan Mode",
      "type": "plan_mode",
      "steps": [
        "Operator: /plan [description]",
        "Orchestrator brainstorms with operator",
        "Spawn scout/researcher/architect subagents (parallel, max 4)",
        "create_task -> task.json",
        "create_plan -> plan.json",
        "finalize_plan -> save artifacts, propose clean session"
      ]
    },
    {
      "id": "FLOW-agent",
      "name": "Agent Mode",
      "type": "agent_mode",
      "steps": [
        "Executor reads plan.json",
        "For each step: form WorkerSpec",
        "spawn_worker -> child_process -> worker writes code -> git commit -> summary.json",
        "Executor reads summary.json",
        "form ReviewerSpec -> spawn_reviewer -> review.json",
        "Executor reads review.json -> approve/reject/escalate",
        "If reject -> correction WorkerSpec -> iter+1",
        "If iter > max_iterations -> STOP, ask operator"
      ]
    },
    {
      "id": "FLOW-onboarding",
      "name": "Onboarding",
      "type": "onboarding",
      "steps": [
        "Operator: /loom-init",
        "Pre-check: git repo? AGENTS.md? knowledge/? Classification.",
        "Analyze AGENTS.md (if exists)",
        "Code archaeology (scout subagent)",
        "Context research (research subagent)",
        "Migration analysis (if foreign_system)",
        "Propose initial rules",
        "Generate minimal AGENTS.md",
        "Operator review and approval",
        "Git commit"
      ]
    },
    {
      "id": "FLOW-tck-migration",
      "name": "Task-Centric Knowledge Migration",
      "type": "migration",
      "steps": [
        "Detect TCK managed block",
        "Extract from AGENTS.md",
        "Migrate tasks: task.md -> task.json, plan.md -> plan.json, sdd.md -> sdd.json",
        "Migrate registry.md -> registry.json",
        "Verification reviewer subagent",
        "If verification ok -> cleanup TCK artifacts",
        "Generate loom AGENTS.md",
        "Operator review",
        "Git commit"
      ]
    }
  ],
