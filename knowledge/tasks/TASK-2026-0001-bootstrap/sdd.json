  "task_id": "TASK-2026-0001-bootstrap",
  "invariant_set": [
    {
      "id": "INV-1",
      "text": "AI-First: JSON primary, markdown derivative",
      "verification": "All knowledge files exist as JSON; markdown is auto-generated derivative"
    },
    {
      "id": "INV-2",
      "text": "Stack-Agnostic: system does not know language/framework",
      "verification": "No language-specific branching in extension code"
    },
    {
      "id": "INV-3",
      "text": "Legacy/Greenfield parity: onboarding works in empty and non-empty projects",
      "verification": "Onboarding pipeline handles clean, partial, foreign_system, mixed_system, compatible states"
    },
    {
      "id": "INV-4",
      "text": "Task-Centric accumulation: each task is an atom, knowledge inherits",
      "verification": "Every task has task.json; registry updated; closed tasks read by agents"
    },
    {
      "id": "INV-5",
      "text": "Operator layers: read-only TUI, docs-as-code",
      "verification": "TUI widgets do not allow code editing; docs generated from code"
    },
    {
      "id": "INV-6",
      "text": "Deterministic context: no implicit state",
      "verification": "Subagents use clean sessions; context assembled from explicit files"
    },
    {
      "id": "INV-7",
      "text": "Pi-Native: extension, not standalone tool",
      "verification": "All code in .pi/extensions/loom/; single agent with different prompts per mode"
    },
    {
      "id": "INV-8",
      "text": "Git-based review: reviewer analyzes artifacts, not session",
      "verification": "Review artifact references git commit hash; reviewer analyzes git diff"
    },
    {
      "id": "INV-9",
      "text": "Executor does not write code: only orchestrates worker + reviewer",
      "verification": "Executor tools: spawn_worker, spawn_reviewer, update_task_status, read_artifact. NO write/edit/commit"
    },
    {
      "id": "INV-10",
      "text": "Models are configurable: no hardcode",
      "verification": "Model config in subagent-config.json; no hardcoded model strings in extension code"
    },
    {
      "id": "INV-11",
      "text": "Strictly sequential execution: step N -> worker -> reviewer -> step N+1",
      "verification": "Executor loop cannot spawn more than one worker simultaneously"
    },
    {
      "id": "INV-12",
      "text": "Localization: UI and user artifacts in Russian; AI documentation in English",
      "verification": "System prompts, JSON schemas, code comments in English; operator text in Russian; machine markers in English"
    },
    {
      "id": "INV-13",
      "text": "Git commit safety: staged list, not git add -A",
      "verification": "Worker commits only files listed in files-to-commit.json"
    },
    {
      "id": "INV-14",
      "text": "Pi CLI verified: all flags for subagent spawner confirmed by PoC",
      "verification": "PoC report confirms --mode json, --system-prompt, --model, --session-dir, --tools work. --system-prompt-file replaced by shell substitution."
    }
  ],
